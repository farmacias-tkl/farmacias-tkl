# =============================================================================
# Farmacias TKL — Variables de entorno
# Copiar este archivo a .env.local para desarrollo local
# NO commitear .env ni .env.local con valores reales
# =============================================================================

# ---------------------------------------------------------------------------
# BASE DE DATOS
# ---------------------------------------------------------------------------
# Desarrollo local: PostgreSQL local
# DATABASE_URL="postgresql://usuario:password@localhost:5432/tkl_dev"
#
# Producción/demo (Neon — recomendado para Vercel):
# DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
#
# Alternativa (Supabase):
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
DATABASE_URL=""

# ---------------------------------------------------------------------------
# NEXTAUTH / AUTENTICACIÓN
# ---------------------------------------------------------------------------
# Secret para firmar JWT. Generar con: openssl rand -base64 32
# En Vercel se puede generar automáticamente desde el panel
NEXTAUTH_SECRET=""

# URL base de la aplicación
# Desarrollo: http://localhost:3000
# Producción: https://tu-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------------------------
# "development" | "production" | "test"
# En desarrollo el seed usa contraseña genérica TKL.Dev.2025!
# En producción genera contraseñas únicas por usuario
NODE_ENV="development"
