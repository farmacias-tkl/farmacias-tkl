// =============================================================================
// Farmacias TKL — Schema Prisma
//
// Cambios en esta versión:
//   - EmployeeBranchAssignment: agrega status (ACTIVE/CANCELLED/COMPLETED)
//   - EmployeeBranchAssignment: agrega positionId? (puesto cubierto)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERVISOR
  BRANCH_MANAGER
  HR
  MAINTENANCE
  OWNER
  ADMIN
}

enum PositionScope {
  ALL
  SPECIFIC
}

// ---------------------------------------------------------------------------
// PermissionScope — alcance de un permiso operativo asignado a un puesto.
//
// OWN_BRANCH    → el permiso aplica solo a la sucursal donde el empleado
//                 esta asignado (Employee.currentBranchId).
// ALL_BRANCHES  → el permiso aplica a cualquier sucursal (uso para roles
//                 cross-branch como supervisor regional).
//
// Conceptualmente DISTINTO de PositionScope (que define a que sucursales
// aplica el puesto en si). No se solapan funcionalmente.
// ---------------------------------------------------------------------------
enum PermissionScope {
  OWN_BRANCH
  ALL_BRANCHES
}

// ---------------------------------------------------------------------------
// AssignmentType — tipo de asignación de sucursal
// ---------------------------------------------------------------------------
enum AssignmentType {
  PERMANENT           // empleado fijo de la sucursal
  TEMPORARY_COVERAGE  // cobertura puntual (vacaciones, ausencia)
  ROTATION            // rotación programada
}

// ---------------------------------------------------------------------------
// AssignmentStatus — estado de la asignación
// ACTIVE    → vigente, se suma al plantel real
// CANCELLED → cancelada antes de iniciarse o durante, no impacta dotación
// COMPLETED → terminada normalmente al vencimiento
// ---------------------------------------------------------------------------
enum AssignmentStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum AbsenceType {
  SICKNESS
  PERSONAL_REASON
  NO_SHOW
  LATE_NOTICE
  LATE_ARRIVAL
  MEDICAL_LEAVE
  SPECIAL_LEAVE
  SUSPENSION
  OTHER
}

enum AbsenceStatus {
  REPORTED
  JUSTIFIED
  UNJUSTIFIED
  UNDER_REVIEW
  CLOSED
}

enum ActionPlanStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

enum ActionPlanTemplateType {
  MOSTRADOR
  CADETE
  CAJERA
  AUDITORIA
}

enum OvertimeStatus {
  REPORTED
  APPROVED
  REJECTED
}

enum OvertimeReason {
  ABSENCE_COVERAGE
  VACATION_COVERAGE
  UNDERSTAFFING
  HIGH_DEMAND
  OTHER
}

// ---------------------------------------------------------------------------
// BRANCH
// ---------------------------------------------------------------------------
model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  aliases   String[] @default([])
  code      String?  @unique
  address   String?
  phone     String?
  active    Boolean  @default(true)
  showInExecutive Boolean @default(true)
  showInOperative Boolean @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  employees            Employee[]
  branchAssignments    EmployeeBranchAssignment[]
  positionScopes       PositionBranchScope[]
  absenceRecords       AbsenceRecord[]
  actionPlans          ActionPlan[]
  overtimeRecords      OvertimeRecord[]
  bankBalanceSnapshots BankBalanceSnapshot[]
  salesSnapshots       SalesSnapshot[]
  vacationRequests     VacationRequest[]
  timeEvents           TimeEvent[]

  @@index([active])
  @@index([showInExecutive])
  @@index([showInOperative])
}

// ---------------------------------------------------------------------------
// POSITION
// ---------------------------------------------------------------------------
model Position {
  id               String        @id @default(cuid())
  name             String        @unique
  requiresCoverage Boolean       @default(false)
  isRotatingRole   Boolean       @default(false)
  scope            PositionScope @default(ALL)
  active           Boolean       @default(true)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  branchScopes        PositionBranchScope[]
  employees           Employee[]
  branchAssignments   EmployeeBranchAssignment[]  // posición cubierta en asignaciones de rotativos
  permissions         PositionPermission[]
  vacationRequests    VacationRequest[]

  @@index([active])
  @@index([requiresCoverage])
}

model PositionBranchScope {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([positionId, branchId])
  @@index([branchId])
}

// ---------------------------------------------------------------------------
// EMPLOYEE
// ---------------------------------------------------------------------------
model Employee {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  positionId      String
  position        Position  @relation(fields: [positionId], references: [id])
  currentBranchId String?
  currentBranch   Branch?   @relation(fields: [currentBranchId], references: [id])
  active          Boolean   @default(true)
  hireDate        DateTime?
  isRotating               Boolean @default(false)
  zone                     String?
  maxConcurrentAssignments Int     @default(1)
  workScheduleNotes String?
  notes             String?
  userId            String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchAssignments EmployeeBranchAssignment[]
  absenceRecords    AbsenceRecord[]
  actionPlans       ActionPlan[]
  overtimeRecords   OvertimeRecord[]
  vacationRequests  VacationRequest[]
  timeEvents        TimeEvent[]

  @@index([currentBranchId])
  @@index([positionId])
  @@index([active])
  @@index([isRotating])
  @@index([lastName, firstName])
}

// ---------------------------------------------------------------------------
// EMPLOYEE BRANCH ASSIGNMENT
//
// Cambios:
//   status:     ACTIVE (impacta plantel) | CANCELLED | COMPLETED
//   positionId: puesto que cubre la rotativa en esa sucursal (opcional)
//
// getPlantillaReal() filtra: status=ACTIVE AND fechas activas
// Las PERMANENT no usan status operativamente (siempre ACTIVE mientras no
// tengan endDate), pero el campo se agrega para consistencia.
// ---------------------------------------------------------------------------
model EmployeeBranchAssignment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])

  startDate DateTime
  endDate   DateTime? // null solo para PERMANENT

  type   AssignmentType  @default(PERMANENT)
  status AssignmentStatus @default(ACTIVE)

  // Puesto que cubre la rotativa en esta asignación (opcional para PERMANENT)
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  reason           String?
  assignedByUserId String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, status])
  @@index([branchId, status])
  @@index([type, status, endDate])
  @@index([startDate, endDate])
}

// ---------------------------------------------------------------------------
// ABSENCE RECORD
// ---------------------------------------------------------------------------
model AbsenceRecord {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  // Snapshots históricos (DM-7) — se llenan al crear, nunca se actualizan.
  // Nullable porque el modelo ya tiene filas; display cae a la relación viva si null.
  employeeNameSnapshot String?
  branchNameSnapshot   String?
  positionNameSnapshot String?
  reportedByUserId String
  startDate        DateTime
  endDate          DateTime
  absenceType      AbsenceType
  status           AbsenceStatus @default(REPORTED)
  hasCertificate   Boolean   @default(false)
  certificateUntil DateTime?
  notifiedAt       DateTime?
  reasonDetail     String?
  notes            String?
  branchDetectedFromAssignment Boolean @default(false)
  whatsappMessageId String?

  // Solo aplican cuando absenceType === LATE_ARRIVAL.
  // lateMinutes es derivado de los dos timestamps anteriores.
  actualArrivalTime   DateTime?
  expectedArrivalTime DateTime?
  lateMinutes         Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stateHistory AbsenceStateHistory[]

  @@index([employeeId])
  @@index([branchId])
  @@index([startDate, endDate])
  @@index([status])
  @@index([absenceType])
}

model AbsenceStateHistory {
  id              String        @id @default(cuid())
  absenceId       String
  absence         AbsenceRecord @relation(fields: [absenceId], references: [id])
  fromStatus      AbsenceStatus
  toStatus        AbsenceStatus
  changedByUserId String
  changedBy       User          @relation(fields: [changedByUserId], references: [id])
  changedAt       DateTime      @default(now())
  note            String?

  @@index([absenceId])
  @@index([changedAt])
}

// ---------------------------------------------------------------------------
// ACTION PLAN
// ---------------------------------------------------------------------------
model ActionPlan {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])
  // Snapshots históricos (DM-7) — se llenan al crear, nunca se actualizan.
  // Nullable porque el modelo ya tiene filas; display cae a la relación viva si null.
  employeeNameSnapshot String?
  branchNameSnapshot   String?
  positionNameSnapshot String?
  createdByUserId String
  date            DateTime
  reason          String
  requiredActions String
  deadline        DateTime
  status          ActionPlanStatus @default(OPEN)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?

  form            ActionPlanForm?

  @@index([employeeId])
  @@index([branchId])
  @@index([status])
  @@index([deadline])
}

// ---------------------------------------------------------------------------
// ACTION PLAN FORM
// ---------------------------------------------------------------------------
model ActionPlanForm {
  id             String                 @id @default(cuid())
  actionPlanId   String                 @unique
  actionPlan     ActionPlan             @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  templateType   ActionPlanTemplateType
  formData       Json
  generalScore    String
  complianceRatio Float?
  improvementPlan String?
  nextReview     DateTime?
  signedAt       DateTime?
  signedDocUrl   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([actionPlanId])
}

// ---------------------------------------------------------------------------
// OVERTIME RECORD
// ---------------------------------------------------------------------------
model OvertimeRecord {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  // Snapshots históricos (DM-7) — se llenan al crear, nunca se actualizan.
  // Nullable porque el modelo ya tiene filas; display cae a la relación viva si null.
  employeeNameSnapshot String?
  branchNameSnapshot   String?
  positionNameSnapshot String?
  reportedByUserId String
  approvedByUserId String?
  approvedAt       DateTime?
  date             DateTime
  hours            Decimal  @db.Decimal(4, 2)
  reason           OvertimeReason
  status           OvertimeStatus @default(REPORTED)
  notes            String?
  rejectionReason  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([branchId])
  @@index([date])
  @@index([status])
}

// ---------------------------------------------------------------------------
// USER
// ---------------------------------------------------------------------------
model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               UserRole
  active             Boolean   @default(true)
  branchId           String?
  branch             Branch?   @relation(fields: [branchId], references: [id])
  employeeId         String?
  mustChangePassword Boolean   @default(true)
  resetToken         String?   @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  accessLogs          AccessLog[]
  securityEvents      SecurityEvent[]
  absenceStateChanges AbsenceStateHistory[]
  vacationsRequested        VacationRequest[] @relation("VacationRequestedBy")
  vacationsSupervisorAction VacationRequest[] @relation("VacationSupervisorAction")
  vacationsRrhhAction       VacationRequest[] @relation("VacationRrhhAction")
  vacationStateChanges      VacationStateHistory[] @relation("VacationStateChangedBy")
  timeEventsReported              TimeEvent[]               @relation("TimeEventReportedBy")
  timeEventsAuthorized            TimeEvent[]               @relation("TimeEventAuthorizedBy")
  timeEventsResolved              TimeEvent[]               @relation("TimeEventResolvedBy")
  timeEventCompsRegistered        TimeEventCompensation[]   @relation("TimeEventCompRegisteredBy")
  timeEventCompsAuthorized        TimeEventCompensation[]   @relation("TimeEventCompAuthorizedBy")
  timeEventStateChanges           TimeEventStateHistory[]   @relation("TimeEventStateChangedBy")

  // Call Center — dominio conversacional (Sprint 1).
  // assignedConversations = dueño-vivo (SetNull por default al borrar el User).
  // sentMessages / conversationStateChanges = histórico-actor inmutable
  // (onDelete: Restrict en la relación, espeja el canon de Vacation/TimeEvent).
  assignedConversations     Conversation[]             @relation("ConversationAssignedTo")
  sentMessages              ConversationMessage[]      @relation("ConversationMessageSender")
  conversationStateChanges  ConversationStateHistory[] @relation("ConversationStateChangedBy")

  // Acceso granular al módulo ejecutivo (independiente del rol).
  // OWNER tiene acceso siempre via canViewExecutive; los demás roles
  // necesitan este flag = true. Default false: usuarios nuevos no tienen
  // acceso a menos que OWNER lo otorgue explícitamente.
  executiveAccess Boolean @default(false)

  // Acceso al módulo Call Center — modelo JERARQUÍA + EXCEPCIÓN (no flag-puro).
  // OWNER/ADMIN/SUPERVISOR entran SIEMPRE por rol (ver canViewCallCenter), sin
  // toggle. El resto (incluido HR) entra solo con callCenterAccess = true,
  // otorgado por OWNER. grantedAt/grantedBy se llenan SOLO al togglear el flag
  // (acceso excepcional); para quienes entran por jerarquía quedan NULL POR
  // DISEÑO — su acceso no es un grant, no es dato faltante.
  callCenterAccess          Boolean   @default(false)
  callCenterAccessGrantedAt DateTime?
  callCenterAccessGrantedBy String?

  @@index([email])
  @@index([role])
  @@index([branchId])
  @@index([executiveAccess])
  @@index([callCenterAccess])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  detail    Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum NotificationType {
  VACATION_NEEDS_COVERAGE
  VACATION_PENDING_APPROVAL
  ROTATING_CONFLICT
  MAINTENANCE_HIGH_PRIORITY
  TASK_OVERDUE
  WHATSAPP_NEEDS_REVIEW
  ABSENCE_REPORTED
  ABSENCE_CRITICAL_POSITION
  ABSENCE_NO_CERTIFICATE
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// ============================================================================
// DASHBOARD EJECUTIVO — enums y modelos
// ============================================================================

enum SyncStatus {
  SUCCESS
  ERROR
  PARTIAL
  NO_FILE
  STALE
}

enum SyncSource {
  GOOGLE_DRIVE
  SALES_API
  EMOZION
}

enum SyncTrigger {
  CRON
  MANUAL
  WEBHOOK
}

enum AccessAction {
  LOGIN
  LOGOUT
  VIEW_DASHBOARD
  VIEW_BALANCES
  VIEW_SALES
  VIEW_COMPARATIVE
  EXPORT
}

model BankBalanceSnapshot {
  id           String   @id @default(cuid())
  branchId     String
  bankName     String
  accountLabel String
  balance      Decimal  @db.Decimal(15, 2)
  checks       Decimal? @db.Decimal(15, 2)
  prevBalance  Decimal? @db.Decimal(15, 2)
  snapshotDate DateTime @db.Date
  sourceSheet  String
  createdAt    DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, bankName, accountLabel, snapshotDate])
  @@index([snapshotDate(sort: Desc)])
  @@index([branchId, snapshotDate(sort: Desc)])
}

model SalesSnapshot {
  id           String   @id @default(cuid())
  branchId     String
  snapshotDate DateTime @db.Date
  totalSales   Decimal  @db.Decimal(15, 2)
  units        Int
  receipts     Int
  avgTicket    Decimal  @db.Decimal(10, 2)
  rawData      Json
  dataSource   String
  createdAt    DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, snapshotDate])
  @@index([snapshotDate(sort: Desc)])
  @@index([branchId, snapshotDate(sort: Desc)])
}

model SyncLog {
  id            String      @id @default(cuid())
  source        SyncSource
  status        SyncStatus
  message       String?
  rowsProcessed Int?
  warnings      Json?
  durationMs    Int?
  syncDate      DateTime    @db.Date
  triggeredBy   SyncTrigger
  createdAt     DateTime    @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([source, syncDate])
}

model SourceFile {
  id           String    @id @default(cuid())
  driveFileId  String    @unique
  filename     String
  fileDate     DateTime  @db.Date
  // modifiedTime del Drive file, para idempotencia por versión:
  // si entre dos runs del mismo día el admin actualiza el Excel, el
  // modifiedTime cambia y syncBalances reprocesa (vs el comportamiento
  // viejo que skipeaba por driveFileId+processedAt date).
  modifiedTime DateTime?
  processedAt  DateTime
  rowsCount    Int
  status       String
  createdAt    DateTime  @default(now())

  @@index([fileDate(sort: Desc)])
}

model AccessLog {
  id           String       @id @default(cuid())
  userId       String
  action       AccessAction
  branchFilter String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// PANEL OWNER — eventos de seguridad
// ============================================================================

enum SecurityEventType {
  EXECUTIVE_ACCESS_GRANTED
  EXECUTIVE_ACCESS_REVOKED
  CALL_CENTER_ACCESS_GRANTED
  CALL_CENTER_ACCESS_REVOKED
  USER_CREATED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_PASSWORD_RESET
  POSITION_PERMISSION_GRANTED
  POSITION_PERMISSION_REVOKED
  POSITION_PERMISSION_SCOPE_CHANGED
}

model SecurityEvent {
  id        String            @id @default(cuid())
  userId    String                                 // sujeto del evento
  user      User              @relation(fields: [userId], references: [id])
  actorId   String?                                // quién lo hizo
  type      SecurityEventType
  detail    Json?
  ip        String?
  userAgent String?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

// ============================================================================
// PERMISOS OPERATIVOS POR PUESTO (Fase 1)
//
// Universo B — permisos operativos. Define que ACCIONES granulares puede
// hacer un usuario dentro de la plataforma operativa, segun su puesto.
//
// SEPARACION ESTRICTA con Universo A (sistema):
//   - Permission contiene SOLO permisos operativos (vencidos.*, caja.*, etc.)
//   - NO contiene permisos de sistema (acceso ejecutivo, panel owner,
//     gestion de usuarios sensibles). Esos quedan en role + executiveAccess.
//
// GOBERNANZA:
//   - OWNER: bypass total en helpers can()/canInBranch() (siempre true).
//   - ADMIN: bypass tecnico (TODO: evaluar remover bypass en Fase 3 si
//     Direccion lo requiere — restringe ADMIN a la gobernanza explicita
//     de los puestos).
//   - OWNER y ADMIN pueden gestionar PositionPermission (asignar/revocar).
//   - Otros roles: deny por default si no hay match en el puesto.
//
// Helpers en Fase 3: src/lib/permissions/positions.ts
//   can(user, key)               -> bypass + lookup por key
//   canInBranch(user, key, bid)  -> idem + resolucion de scope OWN_BRANCH
// ============================================================================

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique           // ej "vencidos.upload_remito"
  module      String                     // ej "vencidos"
  description String                     // texto humano para la UI
  active      Boolean  @default(true)    // soft-delete
  createdAt   DateTime @default(now())

  positions   PositionPermission[]

  @@index([module, active])
}

model PositionPermission {
  id              String          @id @default(cuid())
  positionId      String
  position        Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
  permissionId    String
  permission      Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  scope           PermissionScope @default(OWN_BRANCH)
  grantedByUserId String?         // audit: quien asigno (OWNER o ADMIN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([positionId, permissionId])
  @@index([positionId])
  @@index([permissionId])
}

// ============================================================================
// VACACIONES
//
// Flujo: Encargado solicita → Supervisor aprueba → RRHH confirma → APPROVED.
// Rechazos (de supervisor o RRHH) caen a REJECTED — el motivo y el actor
// quedan en VacationStateHistory + AuditLog.
//
// Snapshots: employeeNameSnapshot, branchNameSnapshot, positionNameSnapshot
// se llenan al crear y NO se actualizan. Sirven para preservar el contexto
// histórico si el empleado cambia de puesto/sucursal o se desactiva.
//
// shiftLabel: preparado para futuro módulo de turnos. Por ahora siempre null
// (lo que genera WARNING en la regla C "mismo puesto + mismo turno").
//
// conflictLevel + conflictReasons: snapshot del resultado de la validación
// al momento del create/edit. Puede recalcularse, pero NO se actualiza en
// cascada cuando otras solicitudes cambian — el helper consulta la verdad.
// ============================================================================

enum VacationStatus {
  PENDING_SUPERVISOR
  PENDING_RRHH
  APPROVED
  REJECTED
  CANCELLED
}

enum VacationConflictLevel {
  NONE
  WARNING
  BLOCKING
}

model VacationRequest {
  id String @id @default(cuid())

  // Relaciones vivas (la fuente de verdad para queries)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  positionId String
  position   Position @relation(fields: [positionId], references: [id])

  // Snapshots históricos — se llenan al crear, nunca se actualizan
  employeeNameSnapshot String
  branchNameSnapshot   String
  positionNameSnapshot String
  shiftLabel           String?

  // Fechas y días
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  daysCount Int

  // Workflow
  status VacationStatus @default(PENDING_SUPERVISOR)

  requestedByUserId        String
  requestedBy              User      @relation("VacationRequestedBy", fields: [requestedByUserId], references: [id])
  supervisorActionByUserId String?
  supervisorActionBy       User?     @relation("VacationSupervisorAction", fields: [supervisorActionByUserId], references: [id])
  supervisorActionAt       DateTime?
  rrhhActionByUserId       String?
  rrhhActionBy             User?     @relation("VacationRrhhAction", fields: [rrhhActionByUserId], references: [id])
  rrhhActionAt             DateTime?

  // Observaciones por rol
  requesterNote  String?
  supervisorNote String?
  rrhhNote       String?

  // Conflictos (snapshot del último cálculo)
  conflictLevel   VacationConflictLevel @default(NONE)
  conflictReasons Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stateHistory VacationStateHistory[]

  @@index([employeeId])
  @@index([branchId])
  @@index([status])
  @@index([startDate, endDate])
}

model VacationStateHistory {
  id              String          @id @default(cuid())
  vacationId      String
  vacation        VacationRequest @relation(fields: [vacationId], references: [id], onDelete: Cascade)
  fromStatus      VacationStatus
  toStatus        VacationStatus
  changedByUserId String
  changedBy       User            @relation("VacationStateChangedBy", fields: [changedByUserId], references: [id])
  changedAt       DateTime        @default(now())
  note            String?

  @@index([vacationId])
  @@index([changedAt])
}

// ============================================================================
// TIME EVENTS — llegadas tarde y retiros anticipados
//
// Modelo separado de AbsenceRecord. El empleado SÍ trabajó pero fuera del
// horario esperado. Se llevan minutos adeudados + compensaciones + resolución
// administrativa.
//
// SEPARACIÓN CRÍTICA entre dos conceptos:
//   - autorización operativa (authorizedBy)    → "te dejo retirarte ahora"
//   - resolución administrativa (resolvedBy)   → "qué hago con la deuda"
//
// LATE_ARRIVAL no requiere autorización (ya pasó). EARLY_DEPARTURE sí: nace
// en PENDING_AUTHORIZATION y queda esperando que SUPERVISOR/HR/ADMIN/OWNER
// lo autorice antes de pasar a PENDING_REVIEW.
//
// PAYROLL DEDUCTION restringido a estados sin compensaciones cargadas
// (PENDING_REVIEW, APPROVED_FOR_COMPENSATION). Una vez iniciada la
// compensación parcial, la resolución debe terminar por esa vía.
//
// El legacy de AbsenceRecord con absenceType=LATE_ARRIVAL se mantiene como
// histórico de solo lectura (no se migra en este sprint).
// ============================================================================

enum TimeEventType {
  LATE_ARRIVAL
  EARLY_DEPARTURE
}

enum TimeEventStatus {
  PENDING_AUTHORIZATION       // solo EARLY_DEPARTURE — espera autorización operativa
  PENDING_REVIEW              // espera resolución administrativa
  APPROVED_FOR_COMPENSATION   // se aprobó compensar minutos
  PARTIALLY_COMPENSATED       // hay al menos una compensación pero falta
  COMPENSATED                 // totalmente saldado
  SENT_TO_PAYROLL_DEDUCTION   // se descuenta del sueldo
  WAIVED                      // condonado
  CANCELLED
}

model TimeEvent {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])

  employeeNameSnapshot String
  branchNameSnapshot   String
  positionNameSnapshot String

  date         DateTime        @db.Date
  type         TimeEventType
  status       TimeEventStatus

  // Tiempos. expectedTime y actualTime son polimórficos:
  //   LATE_ARRIVAL    → entrada (esperada vs real)
  //   EARLY_DEPARTURE → salida  (esperada vs real)
  expectedTime DateTime
  actualTime   DateTime

  // Saldo cacheado (mantenido atómicamente en cada compensación).
  //   minutesRemaining = minutesOwed - minutesCompensated
  // En CANCELLED y WAIVED forzamos minutesRemaining = 0.
  minutesOwed        Int
  minutesCompensated Int @default(0)
  minutesRemaining   Int

  reason       String?     // obligatorio para EARLY_DEPARTURE
  reporterNote String?

  // Autorización operativa (solo EARLY_DEPARTURE)
  authorizedByUserId String?
  authorizedBy       User?    @relation("TimeEventAuthorizedBy", fields: [authorizedByUserId], references: [id])
  authorizedAt       DateTime?
  authorizationNote  String?

  // Resolución administrativa
  resolvedByUserId String?
  resolvedBy       User?    @relation("TimeEventResolvedBy", fields: [resolvedByUserId], references: [id])
  resolvedAt       DateTime?
  resolutionNote   String?

  reportedByUserId String
  reportedBy       User @relation("TimeEventReportedBy", fields: [reportedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compensations TimeEventCompensation[]
  stateHistory  TimeEventStateHistory[]

  @@index([employeeId])
  @@index([branchId])
  @@index([date])
  @@index([status])
  @@index([type])
}

model TimeEventCompensation {
  id                 String    @id @default(cuid())
  timeEventId        String
  timeEvent          TimeEvent @relation(fields: [timeEventId], references: [id], onDelete: Cascade)
  date               DateTime  @db.Date
  minutesCompensated Int

  registeredByUserId String
  registeredBy       User      @relation("TimeEventCompRegisteredBy",  fields: [registeredByUserId], references: [id])
  // Quién autorizó la resolución previa que habilita esta compensación.
  authorizedByUserId String?
  authorizedBy       User?     @relation("TimeEventCompAuthorizedBy",  fields: [authorizedByUserId], references: [id])

  note      String?
  createdAt DateTime @default(now())

  @@index([timeEventId])
  @@index([date])
}

model TimeEventStateHistory {
  id              String          @id @default(cuid())
  timeEventId     String
  timeEvent       TimeEvent       @relation(fields: [timeEventId], references: [id], onDelete: Cascade)
  fromStatus      TimeEventStatus
  toStatus        TimeEventStatus
  changedByUserId String
  changedBy       User            @relation("TimeEventStateChangedBy", fields: [changedByUserId], references: [id])
  changedAt       DateTime        @default(now())
  note            String?

  @@index([timeEventId])
  @@index([changedAt])
}

// ============================================================================
// CALL CENTER — Fundación conversacional (Sprint 1)
//
// Aditivo / expand puro: tablas y enums nuevos, sin tocar nada existente.
// Copia "la forma TKL": snapshots congelados + StateHistory + actor + (en las
// mutaciones del Sprint 2) $transaction. Referencia: Vacaciones / TimeEvent.
//
// RESUELTA NO es terminal: reabre. No lleva guard tipo COMPLETED.
// Whitelist de transiciones: src/lib/call-center/transitions.ts (fuente única).
// ============================================================================

enum ConversationStatus {
  PENDIENTE
  SIN_ASIGNAR
  ASIGNADA
  RESUELTA          // NO terminal — reabre a PENDIENTE/SIN_ASIGNAR
}

enum ConversationMessageAuthor {
  CUSTOMER
  BOT
  OPERATOR
}

model Customer {
  id            String   @id @default(cuid())
  phone         String   @unique          // wa_id / E.164 normalizado
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id                     String             @id @default(cuid())
  customerId             String
  customer               Customer           @relation(fields: [customerId], references: [id])

  status                 ConversationStatus @default(PENDIENTE)
  // dueño-vivo: si se borra el User, la conversación queda libre para reasignar
  // (SetNull por default de relación optional). NO es histórico-actor.
  assignedToUserId       String?
  assignedTo             User?              @relation("ConversationAssignedTo", fields: [assignedToUserId], references: [id])

  category               String?            // scratchpad descartable — NO taxonomía de intents
  customerPhoneSnapshot  String?            // congelado al crear (DM-7)
  externalConversationId String?  @unique   // dedup de dominio (uuid Emozion); nullable → Postgres trata nulls como distintos, las conv manuales de Sprint 2 con null no chocan
  source                 String?            // EMOZION | WHATSAPP_CLOUD | MANUAL — String?, sin enum aún
  externalLabels         String[] @default([]) // staging de labels crudas de Emozion; NO se unifican; futuro = modelo ConversationTag (sub-dominio aparte)

  firstResponseAt        DateTime?
  closedAt               DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  messages               ConversationMessage[]
  stateHistory           ConversationStateHistory[]
  attachments            ConversationAttachment[]

  @@index([status])
  @@index([assignedToUserId])
  @@index([customerId])
  @@index([externalConversationId])
}

model ConversationMessage {
  id                String                    @id @default(cuid())
  conversationId    String
  conversation      Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  author            ConversationMessageAuthor
  // histórico-actor inmutable: un operador con mensajes enviados no se borra
  // físicamente (Restrict). En TKL los users se desactivan, no se borran.
  senderUserId      String?                   // solo cuando author = OPERATOR
  senderUser        User?                     @relation("ConversationMessageSender", fields: [senderUserId], references: [id], onDelete: Restrict)

  body              String?                   // nullable: mensaje solo-media
  mediaUrl          String?                   // provisionado; fixtures = solo texto
  mediaType         String?                   // String?, sin enum aún
  externalMessageId String?  @unique          // dedup de dominio (source_id Emozion / fallback "emozion-message:<id>"); nullable → nulls distintos en Postgres
  externalSenderId  String?                   // sender.id crudo de Emozion; NO se cruza a User TKL aún (cruce por email = dominio futuro)
  isPrivate         Boolean  @default(false)  // notas internas entre operadores; no contaminan el timeline del cliente en el render

  sentAt            DateTime                  // timestamp real (Emozion/WA)
  createdAt         DateTime                  @default(now())

  attachments       ConversationAttachment[]

  @@index([conversationId])
  @@index([externalMessageId])
}

model ConversationStateHistory {
  id                   String              @id @default(cuid())
  conversationId       String
  conversation         Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  fromStatus           ConversationStatus? // null en la fila de nacimiento
  toStatus             ConversationStatus

  fromAssignedToUserId String?             // snapshot del handoff (escalar, como customerPhoneSnapshot)
  toAssignedToUserId   String?

  // actor en forma canónica (FK + relación), pero nullable: la transición
  // automática PENDIENTE→SIN_ASIGNAR (timeout 10') no tiene actor humano.
  // onDelete: Restrict — histórico-actor inmutable, espeja el canon.
  changedByUserId      String?
  changedBy            User?               @relation("ConversationStateChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  changedAt            DateTime            @default(now())
  note                 String?

  @@index([conversationId])
  @@index([changedAt])
}

// ============================================================================
// CALL CENTER — Adjuntos / multimedia (B1: schema base storage-AGNÓSTICO)
//
// Attachment-first: la entidad base es el adjunto. La receta NO es una entidad
// ni un derivado del mediaType: es un valor de documentType, seteado por un
// HUMANO (acción auditada), NUNCA inferido en la ingesta.
//
// B1 = SOLO identidad / vínculo / clasificación / status base / hook de retención.
// NO incluye columnas de storage (URL/provider/estados de rama): esas son B6,
// expand-only, una vez resuelta copia-vs-referencia. Ningún código LEE estas
// columnas todavía (la ingesta de metadata es B2).
// ============================================================================

enum AttachmentSource {
  EMOZION
  INTERNAL
  MIGRATED
}

// SIGNIFICADO documental, NO formato técnico. El formato (image/file/audio/pdf)
// vive en mediaType/mimeType y NO se duplica acá. Default UNKNOWN; lo setea
// SIEMPRE un humano (acción auditada), NUNCA derivado de mediaType en ingesta.
// IMAGE/AUDIO/PDF NO van acá: son formato, ya cubierto por mediaType/mimeType.
// PATIENT_PHOTO se agrega solo si aparece como necesidad operativa real (no ahora).
enum DocumentType {
  UNKNOWN
  PRESCRIPTION
  ARCHIVED_PRESCRIPTION
  RECEIPT
  OTHER
}

// Estados storage-AGNÓSTICOS. NO incluye STORED / AVAILABLE_BY_PROXY: esos
// presuponen una rama de storage y van en B6 (lista 2b).
enum AttachmentStatus {
  RECEIVED   // metadata ingerida OK (sin bytes aún — los bytes son B6)
  PENDING    // creado, esperando un paso posterior (resolución en B6)
  FAILED     // row existe pero con problema conocido y acotado
  REDACTED   // contenido removido por política/legal; el row queda como lápida
  DELETED    // baja lógica
}

/// Estado de la COPIA a storage privado propio (B6).
/// EJE DISTINTO de AttachmentStatus (ciclo documental). NO confundir:
/// AttachmentStatus.PENDING/FAILED/DELETED ≠ StorageStatus.PENDING/FAILED/DELETED.
enum StorageStatus {
  PENDING     // metadata existe, falta copiar (default; aplica también a filas históricas)
  COPYING     // lease de concurrencia del job (evita doble copia)
  STORED      // copia propia confirmada en storage privado
  FAILED      // la copia falló (≠ NO_ORIGIN); reintentable hasta umbral
  NO_ORIGIN   // no hay origen recuperable (histórico sin URL, o el TTL mató la URL). NO auto-recupera.
  DELETED     // objeto propio borrado por retención (baja del archivo, no del row)
}

model ConversationAttachment {
  id               String   @id @default(cuid())

  // onDelete: Restrict — un adjunto puede ser receta/documentación clínica; NO debe
  // borrarse por el borrado de una Conversation. Restrict fuerza una acción explícita
  // de retención/redacción antes de poder borrar la conversación (borrado RUIDOSO, no
  // silencioso). Divergencia DELIBERADA respecto de messages/stateHistory (que usan
  // Cascade en conversationId): la naturaleza clínica lo justifica.
  conversationId   String
  conversation     Conversation         @relation(fields: [conversationId], references: [id], onDelete: Restrict)

  // Opcional: un adjunto nace casi siempre de un mensaje, pero puede sobrevivirlo.
  messageId        String?
  message          ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  source           AttachmentSource @default(EMOZION)
  // id del adjunto en Emozion → idempotencia. Nullable: INTERNAL/MIGRATED no lo tienen
  // (Postgres trata NULLs como distintos, no colisionan). Espeja el patrón de
  // ConversationMessage.externalMessageId.
  sourceExternalId String?  @unique

  // FORMATO TÉCNICO (separado de documentType):
  mediaType        String?  // image | file | audio (lo único que hoy se ingiere). String?, sin enum (espeja ConversationMessage.mediaType)
  mimeType         String?
  originalFileName String?  // PII-sensible (puede contener nombre del paciente) → NUNCA va a logs/AuditLog
  sizeBytes        Int?     // WhatsApp tope ~100MB → Int alcanza

  // SIGNIFICADO documental (separado del formato):
  documentType     DocumentType     @default(UNKNOWN)
  status           AttachmentStatus @default(RECEIVED)

  retentionUntil   DateTime?        // único hook de retención en B1; SIN política/plazo (pendiente legal/interno)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ── STORAGE PRIVADO (B6.1, expand-only, INERTE) ──────────────────────────────────
  // Columnas para la copia a storage propio (R2/S3-compatible). En B6.1 NINGÚN código las
  // lee/escribe: schema inerte aplicado ANTES del código que las use (B6.2 adapter, B6.3
  // job/captura). Todas nullable o con default seguro → ADD COLUMN no-destructivo sobre
  // filas existentes (los históricos quedan storageStatus=PENDING; el job los marcará
  // NO_ORIGIN al no hallar origen).

  /// Estado de copia a storage privado propio. Eje distinto de `status`/AttachmentStatus.
  storageStatus         StorageStatus @default(PENDING)

  /// Proveedor de storage privado ("R2" inicialmente). NO es URL.
  storageProvider       String?

  /// Bucket privado donde quedó/queda el objeto. NO es público.
  storageBucket         String?

  /// Key INTERNA PRIVADA determinística. NO es URL pública; NO se expone.
  storageKey            String?

  /// Content-Type real observado al copiar el archivo.
  storageContentType    String?

  /// Tamaño real copiado al storage privado. Int (WhatsApp topa ~100MB, dentro de Int4).
  storageSizeBytes      Int?

  /// Checksum SHA-256 del objeto copiado, para integridad/idempotencia.
  storageChecksumSha256 String?

  /// Momento en que la copia propia quedó confirmada.
  storageCopiedAt       DateTime?

  /// Cantidad de intentos de copia realizados por el job.
  storageAttemptCount   Int @default(0)

  /// Error técnico saneado del último intento. Nunca URL/PII/bytes.
  storageLastError      String?

  /// Próximo momento habilitado para retry.
  storageNextRetryAt    DateTime?

  /// ORIGEN TÉCNICO TRANSITORIO (data_url Emozion, world-readable / exp:null).
  /// Se NULLEA en el mismo update que marca storageStatus=STORED, y también al agotar
  /// reintentos o por TTL ruidoso. NUNCA fuente de verdad. NUNCA a UI/API/logs/AuditLog.
  /// La captura se activa recién con B6.3 + job + guarda compuesta; hasta entonces INERTE/null.
  sourceFetchUrl        String?

  /// Momento de captura del origen transitorio, usado para TTL/alerta.
  sourceFetchCapturedAt DateTime?

  // PROVENANCE DE CLASIFICACIÓN — decisión explícita de diseño:
  // quién/cuándo setea documentType vive en AuditLog vía el evento ATTACHMENT_CLASSIFIED
  // (action + userId + detail {from,to}), NO como columna de este modelo.
  // NO agregar classifiedByUserId/classifiedAt acá: el row se mantiene en la lista 2a.
  // Si en el futuro se quiere mostrar "clasificado por X" sin join al audit, será una
  // denormalización expand-only en SU momento, no ahora.

  @@index([conversationId])
  @@index([messageId])
  @@index([documentType])
  @@index([status])
  @@index([storageStatus, storageNextRetryAt]) // selección de batch del job de copia (B6.3)
}

// ============================================================================
// CALL CENTER — Ingesta por webhook de Emozion (Sprint 4B)
//
// Log APPEND-ONLY de eventos recibidos: registra cada evento, incluso reenvíos
// (los webhooks se reentregan; queremos VER el reenvío, no rechazarlo). Por eso
// NO lleva @@unique — la deduplicación vive en el DOMINIO (los @unique de
// Conversation.externalConversationId / ConversationMessage.externalMessageId).
// El procesamiento real (mapeo → upsert de dominio) es el processor del 4B 4/4.
// ============================================================================

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  ERROR
  IGNORED
}

model WebhookEvent {
  id                     String             @id @default(cuid())
  source                 SyncSource         @default(EMOZION)
  eventType              String
  accountId              Int
  externalConversationId String?
  externalMessageId      String?
  // payload MÍNIMO NORMALIZADO (lo arma el processor del 4B 4/4): NUNCA
  // custom_attributes/data_url/DNI/teléfono completo. Se nulea tras TTL 7 días.
  // Sin UI; los logs no imprimen contenido. Cifrado de campo = gate de decisión
  // pre-prod (datos de salud, Ley 25.326), no en 4B inicial.
  payload                Json?
  status                 WebhookEventStatus @default(RECEIVED)
  attempts               Int                @default(0)
  receivedAt             DateTime           @default(now())
  processedAt            DateTime?
  error                  String?

  @@index([status, receivedAt])
  @@index([externalConversationId])
}
